# ============================================================
# NAS 媒体库自动化管理工具 — 环境变量配置
# 复制此文件为 .env 并按需修改
# ============================================================

# ---- 基础配置 ----
# 应用名称
APP_NAME="NasTool"
# 应用运行域名（用于生成链接），留空则自动检测
APP_DOMAIN=
# 运行端口（后端 API）
API_PORT=3001
# 调试模式（生产环境设为 false）
DEBUG=false
# 时区
TZ=Asia/Shanghai

# ---- Docker 构建（docker compose build）----
# 仅在需要 Playwright 浏览器（如站点 Cloudflare 绕过）时设为 1；会显著增大后端镜像
# WITH_PLAYWRIGHT_BROWSER=0

# ---- 安全 ----
# JWT 签名密钥（请务必修改为随机字符串）
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
# JWT Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=43200
# 超级管理员用户名（首次启动自动创建）
SUPERUSER=admin
# 超级管理员密码（首次启动自动创建，之后在 UI 中修改）
SUPERUSER_PASSWORD=password

# ---- 数据库 ----
# 数据库类型: sqlite | postgresql
DB_TYPE=sqlite
# SQLite 数据库文件路径
SQLITE_DB_PATH=/data/db/nastool.db
# PostgreSQL 连接 URI（DB_TYPE=postgresql 时生效）
# POSTGRESQL_URI=postgresql+asyncpg://user:password@localhost:5432/nastool

# ---- 数据目录 ----
# 日志目录
LOG_PATH=/data/logs
# 下载目录（下载器存放种子/文件的位置，用于监控）
DOWNLOAD_PATH=/media/downloads
# 媒体库目录（整理后的最终存放位置）
LIBRARY_PATH=/media/library

# ---- 代理配置 ----
# HTTP 代理（留空不使用代理）
PROXY_HOST=
# 是否默认对所有站点使用代理 (true/false)
USE_PROXY=false

# ---- 媒体元数据 ----
# TMDB API Key（从 https://www.themoviedb.org/settings/api 获取）
TMDB_API_KEY=
# 豆瓣（暂使用免费接口，无需 Key）

# ---- 下载器 ----
# qBittorrent
QB_HOST=http://localhost:8080
QB_USERNAME=admin
QB_PASSWORD=adminadmin
QB_CATEGORY=nastool
# Transmission（可选）
TR_HOST=
TR_USERNAME=
TR_PASSWORD=

# ---- 媒体服务器 ----
# Emby（填写其一即可）
EMBY_HOST=
EMBY_API_KEY=
# Jellyfin
JELLYFIN_HOST=
JELLYFIN_API_KEY=
# Plex
PLEX_HOST=
PLEX_TOKEN=

# ---- 消息通知 ----
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 微信推送（可选）
WECHAT_CORP_ID=
WECHAT_CORP_SECRET=
WECHAT_AGENT_ID=

# ---- CookieCloud 同步（可选）----
COOKIECLOUD_HOST=
COOKIECLOUD_KEY=
COOKIECLOUD_PASSWORD=
